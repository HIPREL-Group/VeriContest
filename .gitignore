# Local external dependency checkout. See post2exe/EXTERNAL_DEPS.md.
post2exe/tree-sitter-verus/

# Python caches and generated local artifacts.
__pycache__/
*.py[cod]

# Build outputs that should not be committed.
target/
build/
*.so
*.o
*.rlib

# Exception: the bundled Verus toolchain ships prebuilt runtime libraries that
# ./verus/verus needs to run. Keep them tracked.
!verus/*.so
!verus/*.rlib

# spec_testing runtime
spec_testing/work/
spec_testing/**/__pycache__/
spec_testing/results/
